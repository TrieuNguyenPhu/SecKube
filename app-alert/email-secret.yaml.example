# =============================================================================
# FILE: email-secret.yaml.example
# MÔ TẢ: File mẫu (template) cho email-secret.yaml — AN TOÀN để commit vào Git.
#
# CÁCH SỬ DỤNG:
#   1. Copy file này thành email-secret.yaml:
#      cp email-secret.yaml.example email-secret.yaml
#   2. Thay thế "your-gmail-app-password-16-chars" bằng Gmail App Password thật
#   3. Apply vào cluster:
#      kubectl apply -f email-secret.yaml
#   4. KHÔNG commit email-secret.yaml vào Git (đã có trong .gitignore)
#
# LÝ DO TỒN TẠI FILE NÀY:
#   - Giúp developer mới biết format chính xác của Secret cần tạo
#   - An toàn để commit vì không chứa credentials thật
#   - email-secret.yaml (file thật) bị chặn bởi:
#       + .gitignore — không track trong Git
#       + .argocdignore — ArgoCD không sync lên cluster
#
# CÁCH TẠO GMAIL APP PASSWORD:
#   1. Truy cập https://myaccount.google.com/apppasswords
#   2. Chọn "Mail" → Chọn thiết bị → "Generate"
#   3. Copy mật khẩu 16 ký tự (ví dụ: abcd efgh ijkl mnop → abcdefghijklmnop)
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-email
  # Namespace "monitoring" — phải khớp với namespace của AlertManager
  namespace: monitoring
# Opaque: Loại Secret mặc định cho dữ liệu key-value tùy ý
type: Opaque
# stringData: Khai báo plaintext — Kubernetes tự encode base64 khi lưu
stringData:
  # Thay giá trị bên dưới bằng Gmail App Password thật (16 ký tự)
  password: your-gmail-app-password-16-chars